---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Contato - Portal O Montador de Móveis" description="Entre em contato com o Portal O Montador de Móveis" url="https://portal.omontadordemoveis.com/contato">
	<Header />

	<main class="max-w-4xl mx-auto px-4">
		<section class="py-16">
			<div class="text-center mb-12">
				<span class="inline-flex items-center justify-center w-16 h-16 bg-[#ffb800] rounded-full mb-6">
					<span class="material-symbols-outlined text-3xl text-[#6b4c00]">contact_mail</span>
				</span>
				<h1 class="font-headline text-3xl font-bold text-[#0a1a3c] mb-4">
					Fale Conosco
				</h1>
				<p class="text-[#514532] text-lg">
					Estamos prontos para atendê-lo
				</p>
			</div>

			<div class="grid md:grid-cols-2 gap-8 mb-12">
				<div class="bg-white rounded-xl p-8 ambient-shadow">
					<h2 class="font-headline text-xl font-bold text-[#0a1a3c] mb-6">E-mail</h2>
					<p class="text-[#514532] mb-4">Prefere enviar um e-mail? Respondemos em até 24h úteis.</p>
					<a href="mailto:contato@grupows.com" class="inline-flex items-center gap-2 text-amber-600 font-medium hover:text-amber-700">
						<span class="material-symbols-outlined">email</span>
						contato@grupows.com
					</a>
				</div>

				<div class="bg-white rounded-xl p-8 ambient-shadow">
					<h2 class="font-headline text-xl font-bold text-[#0a1a3c] mb-6">WhatsApp</h2>
					<p class="text-[#514532] mb-4">Fale conosco diretamente pelo WhatsApp!</p>
					<a href="https://api.whatsapp.com/send?phone=5551980168744" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white font-headline font-bold px-6 py-3 rounded-lg transition-colors">
						<span class="material-symbols-outlined">chat</span>
						Chamar no WhatsApp
					</a>
				</div>
			</div>

			<div class="bg-white rounded-xl p-8 ambient-shadow">
				<h2 class="font-headline text-xl font-bold text-[#0a1a3c] mb-6">Enviar Mensagem</h2>
				<form class="space-y-6" action="#" method="POST">
					<div>
						<label for="nome" class="block text-sm font-medium text-[#0a1a3c] mb-2">Nome Completo</label>
						<input
							type="text"
							id="nome"
							name="nome"
							placeholder="Seu nome completo"
							required
							class="w-full h-14 px-4 bg-[#f2f3ff] text-[#0a1a3c] font-body text-base border-none rounded-md appearance-none focus:ring-2 focus:ring-[#ffb800] focus:ring-offset-2 focus:ring-offset-white transition-all placeholder:text-[#514532]/50"
						/>
					</div>

					<div>
						<label for="email" class="block text-sm font-medium text-[#0a1a3c] mb-2">E-mail</label>
						<input
							type="email"
							id="email"
							name="email"
							placeholder="seu@email.com"
							required
							class="w-full h-14 px-4 bg-[#f2f3ff] text-[#0a1a3c] font-body text-base border-none rounded-md appearance-none focus:ring-2 focus:ring-[#ffb800] focus:ring-offset-2 focus:ring-offset-white transition-all placeholder:text-[#514532]/50"
						/>
					</div>

					<div>
						<label for="assunto" class="block text-sm font-medium text-[#0a1a3c] mb-2">Assunto</label>
						<select
							id="assunto"
							name="assunto"
							required
							class="w-full h-14 px-4 bg-[#f2f3ff] text-[#0a1a3c] font-body text-base border-none rounded-md appearance-none focus:ring-2 focus:ring-[#ffb800] focus:ring-offset-2 focus:ring-offset-white transition-all"
						>
							<option disabled selected value="">Selecione um assunto</option>
							<option value="cadastro">Quero me cadastrar como montador</option>
							<option value="cliente">Sou cliente e preciso de um montador</option>
							<option value="duvida">Dúvida geral</option>
							<option value="parceria">Proposta de parceria</option>
							<option value="outro"> outro</option>
						</select>
					</div>

					<div>
						<label for="mensagem" class="block text-sm font-medium text-[#0a1a3c] mb-2">Mensagem</label>
						<textarea
							id="mensagem"
							name="mensagem"
							rows="5"
							placeholder="Digite sua mensagem..."
							required
							class="w-full px-4 py-4 bg-[#f2f3ff] text-[#0a1a3c] font-body text-base border-none rounded-md appearance-none focus:ring-2 focus:ring-[#ffb800] focus:ring-offset-2 focus:ring-offset-white transition-all placeholder:text-[#514532]/50 resize-none"
						></textarea>
					</div>

					<button type="submit" class="w-full h-14 bg-gradient-to-b from-[#ffb800] to-[#f0ad00] text-[#6b4c00] font-headline font-bold text-lg rounded-md flex items-center justify-center gap-2 hover:-translate-y-0.5 transition-transform active:scale-[0.98] shadow-sm">
						<span class="material-symbols-outlined">send</span>
						Enviar Mensagem
					</button>
				</form>
			</div>

			<div class="mt-12 text-center">
				<p class="text-[#514532] text-sm">
					<strong>CNPJ:</strong> 42.197.567/0001-40<br/>
					<strong>Portal O Montador de Móveis</strong> - Catálogo online de profissionais
				</p>
			</div>
		</section>
	</main>
</Layout>