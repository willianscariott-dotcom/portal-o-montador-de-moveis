---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import BottomNavBar from '../components/BottomNavBar.astro';
import MontadorCard from '../components/MontadorCard.astro';
import { supabase } from '../lib/supabase';
import avaliacoesData from '../data/avaliacoes_reais.json';
import { sanitizeCidade, sanitizeNota, filtrarEMontadores, sanitizeMontadorCompleto } from '../lib/sanitizer';

export async function getStaticPaths() {
	try {
		const { data: montadores, error } = await supabase
			.from('tabela_montadores')
			.select('cidade_estado')
			.range(0, 10000);
		
		if (error) {
			console.log('Erro getStaticPaths:', error.message);
			return [];
		}
		
		const data = montadores || [];
		const cidadesUnicas = new Map();
		
		function slugify(text) {
			return text
				.toLowerCase()
				.normalize('NFD')
				.replace(/[\u0300-\u036f]/g, '')
				.replace(/[^a-z0-9]/g, '-')
				.replace(/-+/g, '-')
				.replace(/^-|-$/g, '');
		}
		
		data.forEach(m => {
			if (m.cidade_estado) {
				const [nome, estadoSigla] = m.cidade_estado.split(' - ');
				if (nome && estadoSigla) {
					const slug = slugify(nome);
					const slugComposto = `${slug}-${slugify(estadoSigla)}`;
					if (!cidadesUnicas.has(slug)) {
						cidadesUnicas.set(slug, { id: slug, nome, estadoSigla });
					}
				}
			}
		});
		
		console.log(`getStaticPaths: ${cidadesUnicas.size} cidades únicas encontradas`);
		
		return Array.from(cidadesUnicas.values()).map(c => ({
			params: { cidade: c.id },
			props: { nomeCidade: c.nome, estado: c.estadoSigla }
		}));
	} catch (err) {
		console.log('Erro catch getStaticPaths:', err.message);
		return [];
	}
}

const { nomeCidade, estado } = Astro.props;

function lcg(seed) {
	let state = seed;
	return function() {
		state = (state * 1664525 + 1013904223) % 4294967296;
		return state / 4294967296;
	};
}

const citySlug = nomeCidade.toLowerCase().replace(/[^a-z0-9]/g, '');
const seed = citySlug.split('').reduce((acc, char) => acc + char.charCodeAt(0), 0);
const random = lcg(seed);

const allReviews = avaliacoesData.reviews || [];
const selectedReviews = [];
const usedIndices = new Set();

while (selectedReviews.length < 5 && usedIndices.size < allReviews.length) {
	const idx = Math.floor(random() * allReviews.length);
	if (!usedIndices.has(idx)) {
		usedIndices.add(idx);
		selectedReviews.push(allReviews[idx]);
	}
}

const intros = [
	`Precisa montar um móvel novo ou desmontar para mudança em ${nomeCidade}? Separamos os profissionais mais bem avaliados da região para te ajudar rápido.`,
	`Comprou um móvel novo e precisa de alguém para montar em ${nomeCidade}? Temos os montadores mais recomendados da cidade esperando por você.`,
	`Está procurando montador de móveis em ${nomeCidade}? Aqui você encontra os profissionais mais bem avaliados da região com entrega rápida.`,
	`Montagem de móveis em ${nomeCidade}? Achou! Separamos os melhores montadores da região para você não ter dor de cabeça.`,
	`Precisa de um montador de móveis em ${estado}? Os profissionais mais bem avaliados de ${nomeCidade} estão aqui esperando pelo seu chamado.`,
	`Em ${nomeCidade} e precisa montar aquele guarda-roupa ou estante? Temos os montadores mais bem avaliados da região para te ajudar agora.`
];

const intro = intros[nomeCidade.length % intros.length];

const { data: montadores } = await supabase
	.from('tabela_montadores')
	.select('*')
	.range(0, 10000);

const sanitizados = filtrarEMontadores(montadores || []);

const filtrados = sanitizados.filter(m => 
	m.cidade_estado && m.cidade_estado.toLowerCase().includes(nomeCidade.toLowerCase())
);

const zonasUnicas = new Set();
filtrados.forEach(m => {
	if (m.bairro_zona && m.bairro_zona.toLowerCase() !== 'todos os bairros') {
		zonasUnicas.add(m.bairro_zona);
	}
});
const zonasArray = Array.from(zonasUnicas).sort();

const countText = filtrados.length === 1 
	? '1 profissional encontrado' 
	: `${filtrados.length} profissionais encontrados`;
---

<Layout title={`Montadores de Móveis em ${nomeCidade} - ${estado} | O Montador de Móveis`} description={`Precisa de montador de móveis em ${nomeCidade}? Encontre os melhores profissionais avaliados da região.`} url={`https://portal.omontadordemoveis.com/${Astro.props.cidade}`}>
	<Header />
	<main class="max-w-7xl mx-auto px-4">
		<section class="pt-16 pb-12">
			<a href="/" class="hidden md:inline-flex items-center gap-1 text-[#514532] mb-6 text-sm">
				<span class="material-symbols-outlined text-sm">arrow_back</span>
				Voltar
			</a>
			<h1 class="font-headline text-2xl font-bold text-[#0a1a3c] mb-4">
				Montadores de Móveis em {nomeCidade} - {estado}
			</h1>
			<p class="text-[#514532] text-lg mb-6 max-w-2xl">{intro}</p>
			<p class="text-[#514532] mb-4">{countText}</p>

			{zonasArray.length > 0 && (
				<div class="flex flex-wrap gap-2 mb-6">
					<a href={`/${Astro.props.cidade}`} class="px-4 py-2 rounded-full text-sm font-medium bg-gray-100 text-[#514532] hover:bg-[#ffb800] hover:text-[#6b4c00] transition-colors">
						Todos os bairros
					</a>
					{zonasArray.map(zona => (
						<a href={`/${Astro.props.cidade}/${zona.toLowerCase().replace(/[^a-z0-9]/g, '-')}`} class="px-4 py-2 rounded-full text-sm font-medium bg-white border border-gray-200 text-[#514532] hover:bg-[#ffb800] hover:text-[#6b4c00] hover:border-[#ffb800] transition-colors">
							{zona}
						</a>
					))}
				</div>
			)}

			{filtrados.length === 0 ? (
				<div class="text-center py-12">
					<span class="material-symbols-outlined text-6xl text-[#514532]/30">search_off</span>
					<p class="text-[#514532] mt-4">Ainda não temos montadores cadastrados em {nomeCidade}.</p>
					<a href="/cadastro" class="inline-block mt-4 text-[#ffb800] font-bold">Seja o primeiro a se cadastrar!</a>
				</div>
			) : (
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
					{filtrados.map(m => (
						<MontadorCard 
							nome={m.nome_completo}
							imagem={m.foto_url || ''}
							avaliacao={m.totalScore || 5}
							totalAvaliacoes={m.reviewsCount || 1}
							linkGoogle={m.link_google_empresas || null}
							cidade={nomeCidade}
							estado={estado}
							especialidades={[]}
							online={true}
							telefone={m.whatsapp || ''}
						/>
					))}
				</div>
			)}
		</section>

		<section class="py-12 bg-gray-50">
			<h2 class="font-headline text-2xl font-bold text-[#0a1a3c] mb-8 text-center">
				O que nossos clientes dizem
			</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				{selectedReviews.map(review => (
					<div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
						<div class="flex items-center gap-1 mb-3">
							{Array.from({ length: 5 }).map((_, i) => (
								<svg class={`w-5 h-5 ${i < review.rating ? 'text-[#ffb800]' : 'text-gray-200'}`} fill="currentColor" viewBox="0 0 20 20">
									<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
								</svg>
							))}
						</div>
						<p class="text-[#514532] text-sm mb-4 line-clamp-4">{review.text}</p>
						<p class="font-medium text-[#0a1a3c] text-sm">{review.author}</p>
					</div>
				))}
			</div>
		</section>

		<section class="py-12 border-t border-gray-100">
			<h2 class="font-headline text-2xl font-bold text-[#0a1a3c] mb-8">
				Perguntas Frequentes sobre Montagem de Móveis em {nomeCidade}
			</h2>
			<div class="space-y-4">
				<details class="bg-gray-50 rounded-lg">
					<summary class="px-6 py-4 cursor-pointer font-medium text-[#0a1a3c] flex items-center justify-between">
						Quanto custa a montagem de móveis em {nomeCidade}?
						<span class="material-symbols-outlined text-gray-400">expand_more</span>
					</summary>
					<div class="px-6 pb-4 text-[#514532]">
						O preço varia conforme o tipo e quantidade de móveis. Em média, a montagem de um guarda-roupa ou rack de TV custa entre R$80 e R$150.
					</div>
				</details>
				<details class="bg-gray-50 rounded-lg">
					<summary class="px-6 py-4 cursor-pointer font-medium text-[#0a1a3c] flex items-center justify-between">
						Como escolher um bom montador em {estado}?
						<span class="material-symbols-outlined text-gray-400">expand_more</span>
					</summary>
					<div class="px-6 pb-4 text-[#514532]">
						Veja a nota e quantidade de avaliações do profissional. Prefira quem tem nota acima de 4.5 com várias avaliações.
					</div>
				</details>
				<details class="bg-gray-50 rounded-lg">
					<summary class="px-6 py-4 cursor-pointer font-medium text-[#0a1a3c] flex items-center justify-between">
						O montador vai até minha casa em {nomeCidade}?
						<span class="material-symbols-outlined text-gray-400">expand_more</span>
					</summary>
					<div class="px-6 pb-4 text-[#514532]">
						Sim! Todos os montadores listados fazem atendimento em {nomeCidade}.
					</div>
				</details>
			</div>
		</section>
	</main>

	<div id="modal-overlay" class="fixed inset-0 bg-black/50 hidden z-50 items-center justify-center p-4">
		<div class="bg-white rounded-2xl max-w-md w-full max-h-[90vh] overflow-y-auto">
			<div class="p-6">
				<div class="flex items-center justify-between mb-6">
					<h3 id="modal-title" class="font-headline text-xl font-bold text-[#0a1a3c]">
						Falar com Profissional
					</h3>
					<button id="modal-close" class="text-gray-400 hover:text-gray-600">
						<span class="material-symbols-outlined">close</span>
					</button>
				</div>
				
				<div id="step-1">
					<div class="mb-4">
						<label class="block text-sm font-medium text-[#0a1a3c] mb-2">Seu Nome</label>
						<input type="text" id="lead-nome" class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-[#ffb800] focus:border-transparent outline-none" placeholder="Como você se chama?" />
					</div>
					<button type="button" id="btn-next-1" class="w-full bg-[#ffb800] hover:bg-[#f0ad00] text-[#6b4c00] font-bold py-3 rounded-lg transition-colors">
						Avançar
					</button>
				</div>
				
				<div id="step-2" class="hidden">
					<div class="mb-4">
						<label class="block text-sm font-medium text-[#0a1a3c] mb-2">Seu WhatsApp</label>
						<input type="tel" id="lead-telefone" class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-[#ffb800] focus:border-transparent outline-none" placeholder="(11) 99999-9999" />
					</div>
					<button type="button" id="btn-next-2" class="w-full bg-[#ffb800] hover:bg-[#f0ad00] text-[#6b4c00] font-bold py-3 rounded-lg transition-colors">
						Avançar
					</button>
					<button type="button" id="btn-back-2" class="w-full mt-2 text-gray-500 hover:text-gray-700 py-2">
						Voltar
					</button>
				</div>
				
				<div id="step-3" class="hidden">
					<div class="mb-4">
						<label class="block text-sm font-medium text-[#0a1a3c] mb-2">Cidade onde você precisa do serviço</label>
						<input type="text" id="lead-cidade-input" class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-[#ffb800] focus:border-transparent outline-none" placeholder="Ex: Porto Alegre" />
					</div>
					<div class="mb-4">
						<label class="block text-sm font-medium text-[#0a1a3c] mb-2">O que você precisa montar/desmontar?</label>
						<input type="text" id="lead-servico" class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-[#ffb800] focus:border-transparent outline-none" placeholder="Ex: Guarda-roupa, Cozinha..." />
					</div>
					<input type="hidden" id="lead-montador" value="" />
					<input type="hidden" id="lead-telefone-montador" value="" />
					<input type="hidden" id="lead-cidade" value={nomeCidade} />
					<button type="button" id="btn-enviar" class="track-lead-whatsapp w-full bg-green-500 hover:bg-green-600 text-white font-bold py-3 rounded-lg transition-colors flex items-center justify-center gap-2">
						<span class="material-symbols-outlined">chat</span>
						Enviar no WhatsApp
					</button>
					<button type="button" id="btn-back-3" class="w-full mt-2 text-gray-500 hover:text-gray-700 py-2">
						Voltar
					</button>
				</div>
			</div>
		</div>
	</div>

	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "FAQPage",
		"mainEntity": [
			{"@type": "Question", "name": `Quanto custa a montagem de móveis em ${nomeCidade}?`, "acceptedAnswer": {"@type": "Answer", "text": "O preço varia conforme o tipo e quantidade de móveis."}},
			{"@type": "Question", "name": `Como escolher um bom montador em ${estado}?`, "acceptedAnswer": {"@type": "Answer", "text": "Veja a nota e quantidade de avaliações."}}
		]
	})} />

	{selectedReviews.length > 0 && (
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "AggregateRating",
			"itemReviewed": {
				"@type": "LocalBusiness",
				"name": "O Montador de Móveis",
				"areaServed": nomeCidade
			},
			"ratingValue": 5,
			"reviewCount": selectedReviews.length,
			"bestRating": 5
		})} />
	)}

	<BottomNavBar />

	<script>
		const nomeCidade = "{nomeCidade}";
		
		var modalOverlay = document.getElementById("modal-overlay");
		var modalTitle = document.getElementById("modal-title");
		var leadForm = document.getElementById("lead-form");
		var leadMontadorInput = document.getElementById("lead-montador");
		var leadTelefoneInput = document.getElementById("lead-telefone-montador");
		var leadCidadeInput = document.getElementById("lead-cidade");
		var modalClose = document.getElementById("modal-close");

		document.querySelectorAll(".btn-whatsapp").forEach(function(btn) {
			btn.addEventListener("click", function(e) {
				var target = e.currentTarget;
				var nome = target.getAttribute("data-nome") || "";
				var telefone = target.getAttribute("data-telefone") || "";
				var cidadeDoMontador = target.getAttribute("data-cidade") || nomeCidade;
				if (modalTitle) modalTitle.textContent = "Falar com " + nome;
				if (leadMontadorInput) leadMontadorInput.value = nome;
				if (leadTelefoneInput) leadTelefoneInput.value = telefone;
				if (leadCidadeInput) leadCidadeInput.value = nomeCidade;
				modalOverlay.classList.remove("hidden");
				modalOverlay.classList.add("flex");
			});
		});

		modalClose.addEventListener("click", function() {
			modalOverlay.classList.add("hidden");
			modalOverlay.classList.remove("flex");
		});

		modalOverlay.addEventListener("click", function(e) {
			if (e.target === modalOverlay) {
				modalOverlay.classList.add("hidden");
				modalOverlay.classList.remove("flex");
			}
		});

		document.getElementById("btn-next-1").addEventListener("click", function() {
			var nome = document.getElementById("lead-nome").value;
			if (!nome) { alert("Preencha seu nome!"); return; }
			document.getElementById("step-1").classList.add("hidden");
			document.getElementById("step-2").classList.remove("hidden");
		});
		
		document.getElementById("btn-next-2").addEventListener("click", function() {
			var telefone = document.getElementById("lead-telefone").value;
			if (!telefone) { alert("Preencha seu WhatsApp!"); return; }
			document.getElementById("step-2").classList.add("hidden");
			document.getElementById("step-3").classList.remove("hidden");
		});
		
		document.getElementById("btn-back-2").addEventListener("click", function() {
			document.getElementById("step-2").classList.add("hidden");
			document.getElementById("step-1").classList.remove("hidden");
		});
		
		document.getElementById("btn-back-3").addEventListener("click", function() {
			document.getElementById("step-3").classList.add("hidden");
			document.getElementById("step-2").classList.remove("hidden");
		});
		
		document.getElementById("btn-enviar").addEventListener("click", function() {
			var nome = document.getElementById("lead-nome").value;
			var cidade = document.getElementById("lead-cidade-input").value;
			var servico = document.getElementById("lead-servico").value;
			var nomeMontador = leadMontadorInput.value;
			var telefoneMontador = leadTelefoneInput.value;
			if (!nome || !servico || !nomeMontador || !cidade) { alert("Preencha todos os campos!"); return; }
			if (!telefoneMontador) { alert("Número do montador não encontrado!"); return; }
			var telefoneLimpo = "55" + telefoneMontador.replace(/\D/g, "");
			var mensagem = "Olá " + nomeMontador + ", me chamo " + nome + ". Te encontrei no Portal O Montador de Móveis e preciso de um montador para " + servico + " em " + cidade + ".";
			var urlWhatsapp = "https://wa.me/" + telefoneLimpo + "?text=" + encodeURIComponent(mensagem);
			window.open(urlWhatsapp, "_blank");
			modalOverlay.classList.add("hidden");
			modalOverlay.classList.remove("flex");
			document.getElementById("lead-nome").value = "";
			document.getElementById("lead-telefone").value = "";
			document.getElementById("lead-servico").value = "";
		});
	</script>

	<style>
		details > summary { list-style: none; }
		details > summary::-webkit-details-marker { display: none; }
		details[open] summary .material-symbols-outlined { transform: rotate(180deg); }
		.material-symbols-outlined { transition: transform 0.2s; }
	</style>
</Layout>