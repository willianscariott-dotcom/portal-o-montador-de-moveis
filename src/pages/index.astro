---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import BottomNavBar from '../components/BottomNavBar.astro';

const citiesData = [
	{ id: "maceio", nome: "Maceió" },
	{ id: "manaus", nome: "Manaus" },
	{ id: "salvador", nome: "Salvador" },
	{ id: "fortaleza", nome: "Fortaleza" },
	{ id: "brasilia", nome: "Brasília" },
	{ id: "goiania", nome: "Goiânia" },
	{ id: "sao-luis", nome: "São Luís" },
	{ id: "belo-horizonte", nome: "Belo Horizonte" },
	{ id: "uberlandia", nome: "Uberlândia" },
	{ id: "campo-grande", nome: "Campo Grande" },
	{ id: "cuiaba", nome: "Cuiabá" },
	{ id: "belem", nome: "Belém" },
	{ id: "joao-pessoa", nome: "João Pessoa" },
	{ id: "recife", nome: "Recife" },
	{ id: "teresina", nome: "Teresina" },
	{ id: "curitiba", nome: "Curitiba" },
	{ id: "rio-de-janeiro", nome: "Rio de Janeiro" },
	{ id: "natal", nome: "Natal" },
	{ id: "porto-alegre", nome: "Porto Alegre" },
	{ id: "canoas", nome: "Canoas" },
	{ id: "cachoeirinha", nome: "Cachoeirinha" },
	{ id: "gravatai", nome: "Gravataí" },
	{ id: "viamao", nome: "Viamão" },
	{ id: "sao-leopoldo", nome: "São Leopoldo" },
	{ id: "novo-hamburgo", nome: "Novo Hamburgo" },
	{ id: "alvorada", nome: "Alvorada" },
	{ id: "dois-irmaos", nome: "Dois Irmãos" },
	{ id: "campo-bom", nome: "Campo Bom" },
	{ id: "estancia-velha", nome: "Estância Velha" },
	{ id: "igrejinha", nome: "Igrejinha" },
	{ id: "parobe", nome: "Parobé" },
	{ id: "portao", nome: "Portão" },
	{ id: "sapiranga", nome: "Sapiranga" },
	{ id: "sapucaia-do-sul", nome: "Sapucaia do Sul" },
	{ id: "aracaju", nome: "Aracaju" },
	{ id: "sao-paulo", nome: "São Paulo" },
	{ id: "campinas", nome: "Campinas" },
	{ id: "guarulhos", nome: "Guarulhos" },
	{ id: "sao-bernardo-do-campo", nome: "São Bernardo do Campo" },
	{ id: "osasco", nome: "Osasco" },
	{ id: "ribeirao-preto", nome: "Ribeirão Preto" },
	{ id: "santoandre", nome: "Santo André" },
	{ id: "sao-jose-dos-campos", nome: "São José dos Campos" },
	{ id: "sorocaba", nome: "Sorocaba" },
	{ id: "duque-de-caxias", nome: "Duque de Caxias" },
	{ id: "sao-goncalo", nome: "São Gonçalo" },
	{ id: "jaboatao-dos-guararapes", nome: "Jaboatão dos Guararapes" }
];
---

<Layout title="Portal O Montador - Encontre Montadores de Móveis Próximos a Você">
	<Header />

	<main>
		<section class="relative min-h-[85vh] flex items-center overflow-hidden">
			<div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900"></div>
			<div class="absolute top-20 left-10 w-72 h-72 bg-amber-500/20 rounded-full blur-[120px]"></div>
			<div class="absolute bottom-20 right-10 w-96 h-96 bg-amber-400/10 rounded-full blur-[100px]"></div>
			
			<div class="absolute inset-0 opacity-30">
				<svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
					<defs>
						<pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
							<path d="M 60 0 L 0 0 0 60" fill="none" stroke="white" stroke-width="0.5" opacity="0.1"/>
						</pattern>
					</defs>
					<rect width="100%" height="100%" fill="url(#grid)" />
				</svg>
			</div>

			<div class="relative z-10 max-w-7xl mx-auto px-6 py-16 w-full">
				<div class="grid lg:grid-cols-2 gap-12 items-center">
					<div class="text-center lg:text-left">
						<div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 mb-6">
							<span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
							<span class="text-white/80 text-sm font-medium">+400 profissionais ativos</span>
						</div>
						
						<h1 class="font-headline text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
							Encontre os Melhores
							<span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-400 to-amber-600">
								Montadores de Móveis
							</span>
							do Brasil
						</h1>
						
						<p class="text-lg text-slate-300 mb-8 max-w-xl mx-auto lg:mx-0">
							O maior e mais seguro portal de montagem. Presente em mais de 15 estados e 40 cidades. 
							Conectamos você a profissionais rigorosamente avaliados.
						</p>

						<div class="flex flex-wrap justify-center lg:justify-start gap-4 text-slate-400 text-sm">
							<div class="flex items-center gap-2">
								<span class="material-symbols-outlined text-amber-400">verified</span>
								<span>Profissionais Verificados</span>
							</div>
							<div class="flex items-center gap-2">
								<span class="material-symbols-outlined text-amber-400">star</span>
								<span>Avaliados</span>
							</div>
							<div class="flex items-center gap-2">
								<span class="material-symbols-outlined text-amber-400">support_agent</span>
								<span>Suporte</span>
							</div>
						</div>
					</div>

					<div class="relative">
						<div class="absolute -inset-4 bg-gradient-to-r from-amber-500/20 to-amber-600/20 rounded-3xl blur-2xl"></div>
						
						<div class="relative bg-white/10 backdrop-blur-xl border border-white/20 rounded-2xl p-8 shadow-2xl">
							<h2 class="text-white font-headline text-xl font-semibold mb-6 text-center">
								Encontre um montador agora
							</h2>
							
							<form class="space-y-4">
								<div class="relative">
									<label class="sr-only" for="estado">Estado</label>
									<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">map</span>
									<select class="w-full h-14 pl-12 pr-12 bg-white/90 text-slate-800 font-medium rounded-xl appearance-none focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all cursor-pointer" id="estado" name="estado" required>
										<option disabled selected value="">Selecione o Estado</option>
									</select>
									<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none">expand_more</span>
								</div>
								
								<div class="relative">
									<label class="sr-only" for="cidade">Cidade</label>
									<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">location_city</span>
									<select class="w-full h-14 pl-12 pr-12 bg-white/90 text-slate-800 font-medium rounded-xl appearance-none focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all cursor-pointer" id="cidade" name="cidade" required disabled>
										<option disabled selected value="">Selecione a Cidade</option>
									</select>
									<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none">expand_more</span>
								</div>
								
								<button type="submit" class="w-full h-14 bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-400 hover:to-amber-500 text-slate-900 font-headline font-bold text-lg rounded-xl flex items-center justify-center gap-2 transition-all hover:shadow-lg hover:shadow-amber-500/25 active:scale-[0.98]">
									<span class="material-symbols-outlined" style="font-variation-settings: 'wght' 600;">search</span>
									Buscar Montador
								</button>
							</form>
							
							<p class="text-slate-400 text-xs text-center mt-4">
								Busca gratuita. Sem compromisso.
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="py-16 bg-slate-50">
			<div class="max-w-7xl mx-auto px-6">
				<h2 class="font-headline text-2xl font-bold text-slate-800 text-center mb-10">
					Principais Cidades Atendidas
				</h2>
				<div class="flex flex-wrap justify-center gap-3">
					{citiesData.map((cidade) => (
						<a href={`/${cidade.id}`} class="bg-white hover:bg-amber-50 border border-slate-200 hover:border-amber-300 text-slate-700 hover:text-amber-700 font-medium py-2 px-4 rounded-full transition-all hover:shadow-md">
							{cidade.nome}
						</a>
					))}
				</div>
			</div>
		</section>
	</main>

	<BottomNavBar />
</Layout>

<script>
	const estadoSelect = document.getElementById('estado');
	const cidadeSelect = document.getElementById('cidade');

	const estadosBrasileiros = {
		'AL': 'Alagoas', 'AM': 'Amazonas', 'BA': 'Bahia', 'CE': 'Ceará',
		'DF': 'Distrito Federal', 'GO': 'Goiás', 'MA': 'Maranhão', 'MG': 'Minas Gerais',
		'MS': 'Mato Grosso do Sul', 'MT': 'Mato Grosso', 'PA': 'Pará', 'PB': 'Paraíba',
		'PE': 'Pernambuco', 'PI': 'Piauí', 'PR': 'Paraná', 'RJ': 'Rio de Janeiro',
		'RN': 'Rio Grande do Norte', 'RS': 'Rio Grande do Sul', 'SE': 'Sergipe', 'SP': 'São Paulo'
	};

	const locaisDeAtendimento = {
		"AL": ["Maceió"], "AM": ["Manaus"], "BA": ["Salvador"], "CE": ["Fortaleza"],
		"DF": ["Brasília"], "GO": ["Goiânia"], "MA": ["São Luís"], "MG": ["Belo Horizonte", "Uberândia"],
		"MS": ["Campo Grande"], "MT": ["Cuiabá"], "PA": ["Belém"], "PB": ["João Pessoa"],
		"PE": ["Jaboatão dos Guararapes", "Recife"], "PI": ["Teresina"], "PR": ["Curitiba"],
		"RJ": ["Duque de Caxias", "Rio de Janeiro", "São Gonçalo"], "RN": ["Natal"],
		"RS": ["Alvorada", "Cachoeirinha", "Campo Bom", "Canoas", "Dois Irmãos", "Estância Velha", "Gravataí", "Igrejinha", "Novo Hamburgo", "Parobé", "Portão", "Porto Alegre", "Sapiranga", "Sapucaia do Sul", "São Leopoldo", "Viamão"],
		"SE": ["Aracaju"], "SP": ["Campinas", "Guarulhos", "Osasco", "Ribeirão Preto", "Santo André", "São Bernardo do Campo", "São José dos Campos", "São Paulo", "Sorocaba"]
	};

	function carregarEstados() {
		const estadosOrdenados = Object.keys(locaisDeAtendimento).sort();
		estadosOrdenados.forEach(function(uf) {
			const nome = estadosBrasileiros[uf] || uf;
			const option = document.createElement('option');
			option.value = uf;
			option.textContent = nome;
			estadoSelect.appendChild(option);
		});
	}

	estadoSelect.addEventListener('change', function() {
		const ufSelecionado = estadoSelect.value;
		cidadeSelect.innerHTML = '<option disabled selected value="">Selecione a Cidade</option>';
		
		if (locaisDeAtendimento[ufSelecionado]) {
			locaisDeAtendimento[ufSelecionado].sort().forEach(function(cidade) {
				const slug = cidade.toLowerCase()
					.normalize('NFD').replace(/[\u0300-\u036f]/g, '')
					.replace(/ã/g, 'a').replace(/õ/g, 'o')
					.replace(/\s+/g, '-');
				const option = document.createElement('option');
				option.value = slug;
				option.textContent = cidade;
				cidadeSelect.appendChild(option);
			});
			cidadeSelect.disabled = false;
		} else {
			cidadeSelect.disabled = true;
		}
	});

	carregarEstados();

	const form = document.querySelector('form');
	form.addEventListener('submit', function(e) {
		e.preventDefault();
		const estado = estadoSelect.value;
		const cidade = cidadeSelect.value;
		if (!estado || !cidade) {
			alert('Por favor, selecione o Estado e a Cidade.');
			return;
		}
		window.location.href = '/' + cidade;
	});
</script>