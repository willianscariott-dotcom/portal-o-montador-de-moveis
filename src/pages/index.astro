---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import BottomNavBar from '../components/BottomNavBar.astro';
import { supabase } from '../lib/supabase';
import { citiesData } from '../data/cities.js';

const { data: montadores } = await supabase
	.from('montadores_pendentes')
	.select('cidade_estado');

const cidadesMap = new Map();

if (!montadores || montadores.length === 0) {
	citiesData.forEach(c => {
		cidadesMap.set(c.nome, {
			id: c.id,
			nome: c.nome,
			estado: c.estadoSigla
		});
	});
} else {
	montadores.forEach(m => {
		if (m.cidade_estado) {
			const [nome, sigla] = m.cidade_estado.split(' - ');
			if (nome && sigla && !cidadesMap.has(nome)) {
				cidadesMap.set(nome, {
					id: nome.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, ''),
					nome,
					estado: sigla
				});
			}
		}
	});
}

const citiesByRegion = [
	{ region: "Sudeste", cities: [] },
	{ region: "Sul", cities: [] },
	{ region: "Nordeste", cities: [] },
	{ region: "Centro-Oeste", cities: [] },
	{ region: "Norte", cities: [] }
];

const estadoRegiao = {
	'SP': 'Sudeste', 'RJ': 'Sudeste', 'MG': 'Sudeste', 'ES': 'Sudeste',
	'RS': 'Sul', 'SC': 'Sul', 'PR': 'Sul',
	'BA': 'Nordeste', 'PE': 'Nordeste', 'CE': 'Nordeste', 'RN': 'Nordeste', 
	'PB': 'Nordeste', 'AL': 'Nordeste', 'SE': 'Nordeste', 'MA': 'Nordeste', 'PI': 'Nordeste',
	'DF': 'Centro-Oeste', 'GO': 'Centro-Oeste', 'MT': 'Centro-Oeste', 'MS': 'Centro-Oeste',
	'AM': 'Norte', 'PA': 'Norte', 'RO': 'Norte', 'AC': 'Norte', 'AP': 'Norte', 'RR': 'Norte', 'TO': 'Norte'
};

Array.from(cidadesMap.values()).forEach(c => {
	const regiao = estadoRegiao[c.estado] || 'Sudeste';
	const regionObj = citiesByRegion.find(r => r.region === regiao);
	if (regionObj && !regionObj.cities.find(ci => ci.nome === c.nome)) {
		regionObj.cities.push(c);
	}
});

citiesByRegion.forEach(r => {
	r.cities.sort((a, b) => a.nome.localeCompare(b.nome));
});

const totalMontadores = montadores?.length || 0;

const locaisDeAtendimentoData = {};
Array.from(cidadesMap.values()).forEach(c => {
	if (!locaisDeAtendimentoData[c.estado]) locaisDeAtendimentoData[c.estado] = [];
	if (!locaisDeAtendimentoData[c.estado].includes(c.nome)) {
		locaisDeAtendimentoData[c.estado].push(c.nome);
	}
});
---

<Layout title="Portal O Montador - Encontre Montadores de Móveis Próximos a Você" description="Encontre montadores de móveis profissionais próximos de você. Serviço rápido, seguro e com garantia. Solicite seu orçamento agora!" url="https://portal.omontadordemoveis.com">
	<Header />

	<main>
		<section aria-labelledby="hero-heading" class="relative min-h-[85vh] flex items-center overflow-hidden">
			<div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900"></div>
			<div class="absolute top-20 left-10 w-72 h-72 bg-amber-500/20 rounded-full blur-[120px]"></div>
			<div class="absolute bottom-20 right-10 w-96 h-96 bg-amber-400/10 rounded-full blur-[100px]"></div>
			
			<div class="absolute inset-0 opacity-30">
				<svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
					<defs>
						<pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
							<path d="M 60 0 L 0 0 0 60" fill="none" stroke="white" stroke-width="0.5" opacity="0.1"/>
						</pattern>
					</defs>
					<rect width="100%" height="100%" fill="url(#grid)" />
				</svg>
			</div>

			<article class="relative z-10 max-w-7xl mx-auto px-6 py-16 w-full">
				<div class="grid lg:grid-cols-2 gap-16 items-center">
					<div>
						<div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 mb-6">
							<span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
							<span class="text-white/80 text-sm font-medium">{totalMontadores} profissionais ativos</span>
						</div>
						
						<h1 id="hero-heading" class="font-headline text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
							Encontre o Melhor Montador de Móveis
							<br />
							<span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-400 to-amber-600">
								na sua Cidade
							</span>
						</h1>
						
						<p class="text-lg text-slate-300 mb-8 max-w-lg">
							Conectamos você a profissionais especializados em <strong>instalação de móveis</strong> com 
							<strong>segurança residencial</strong> garantida. 
							Contato direto via <strong>WhatsApp</strong> para 
							<strong>orçamentos</strong> transparentes.
						</p>

						<div class="flex flex-wrap gap-6 text-slate-400 text-sm">
							<div class="flex items-center gap-2">
								<span class="material-symbols-outlined text-amber-400">verified</span>
								<span>Profissionais Verificados</span>
							</div>
							<div class="flex items-center gap-2">
								<span class="material-symbols-outlined text-amber-400">star</span>
								<span>Avaliados</span>
							</div>
							<div class="flex items-center gap-2">
								<span class="material-symbols-outlined text-amber-400">support_agent</span>
								<span>Suporte</span>
							</div>
						</div>
					</div>

					<div class="relative">
						<div class="absolute -inset-4 bg-gradient-to-r from-amber-500/20 to-amber-600/20 rounded-3xl blur-2xl"></div>
						
						<div class="relative bg-white/10 backdrop-blur-xl border border-white/20 rounded-2xl p-8 shadow-2xl">
							<h2 class="text-white font-headline text-xl font-semibold mb-6 text-center">
								Encontre um montador agora
							</h2>
							
							<form class="space-y-4">
								<div class="relative">
									<label class="sr-only" for="estado">Estado</label>
									<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">map</span>
									<select class="w-full h-14 pl-12 pr-12 bg-white/90 text-slate-800 font-medium rounded-xl appearance-none focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all cursor-pointer" id="estado" name="estado" required>
										<option disabled selected value="">Selecione o Estado</option>
									</select>
									<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none">expand_more</span>
								</div>
								
								<div class="relative">
									<label class="sr-only" for="cidade">Cidade</label>
									<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">location_city</span>
									<select class="w-full h-14 pl-12 pr-12 bg-white/90 text-slate-800 font-medium rounded-xl appearance-none focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all cursor-pointer" id="cidade" name="cidade" required disabled>
										<option disabled selected value="">Selecione a Cidade</option>
									</select>
									<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none">expand_more</span>
								</div>
								
								<button type="submit" class="w-full h-14 bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-400 hover:to-amber-500 text-slate-900 font-headline font-bold text-lg rounded-xl flex items-center justify-center gap-2 transition-all hover:shadow-lg hover:shadow-amber-500/25 active:scale-[0.98]">
									<span class="material-symbols-outlined" style="font-variation-settings: 'wght' 600;">search</span>
									Buscar Montador
								</button>
							</form>
							
							<p class="text-slate-400 text-xs text-center mt-4">
								Busca gratuita. Sem compromisso.
							</p>
						</div>
					</div>
				</div>
			</article>
		</section>

		<section aria-labelledby="como-funciona-heading" class="py-20 bg-slate-50">
			<div class="max-w-4xl mx-auto px-6">
				<h2 id="como-funciona-heading" class="font-headline text-2xl font-bold text-slate-800 text-center mb-12">
					Como Funciona o Portal O Montador de Móveis
				</h2>
				<ol class="space-y-8">
					<li class="flex gap-6 items-start">
						<span class="flex-shrink-0 w-12 h-12 bg-amber-500 text-slate-900 font-bold rounded-full flex items-center justify-center text-lg">1</span>
						<div>
							<h3 class="font-semibold text-slate-800 text-lg mb-2">Busque por sua Cidade</h3>
							<p class="text-slate-600">Selecione seu estado e cidade no formulário acima. O sistema conecta você aos melhores <strong>montadores de móveis</strong> da região.</p>
						</div>
					</li>
					<li class="flex gap-6 items-start">
						<span class="flex-shrink-0 w-12 h-12 bg-amber-500 text-slate-900 font-bold rounded-full flex items-center justify-center text-lg">2</span>
						<div>
							<h3 class="font-semibold text-slate-800 text-lg mb-2">Compare Profissionais Avaliados</h3>
							<p class="text-slate-600">Acesse perfis de especialistas em <strong>montagem</strong> e <strong>instalação profissional</strong>. Veja notas e avaliações reais de clientes.</p>
						</div>
					</li>
					<li class="flex gap-6 items-start">
						<span class="flex-shrink-0 w-12 h-12 bg-amber-500 text-slate-900 font-bold rounded-full flex items-center justify-center text-lg">3</span>
						<div>
							<h3 class="font-semibold text-slate-800 text-lg mb-2">Contato Direto via WhatsApp</h3>
							<p class="text-slate-600">Converse diretamente com o montador. Receba <strong>orçamentos</strong> transparentes e aproveite a <strong>segurança residencial</strong> de um serviço profesionalescolhido.</p>
						</div>
					</li>
				</ol>
			</div>
		</section>
	</main>

	<footer class="bg-slate-900 py-16">
		<div class="max-w-7xl mx-auto px-6">
			<nav aria-label="Nossas Cidades" class="mb-12">
				<h2 class="font-headline text-lg font-semibold text-white mb-6">Encontre montadores de móveis em:</h2>
				<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8">
					{citiesByRegion.map((region) => (
						<div>
							<h3 class="text-amber-500 font-medium text-sm mb-3">{region.region}</h3>
							<ul class="space-y-2">
								{region.cities.map((cidade) => (
									<li>
										<a href={`/${cidade.id}`} class="text-slate-500 hover:text-amber-400 text-xs transition-colors">
											{cidade.nome}
										</a>
									</li>
								))}
							</ul>
						</div>
					))}
				</div>
			</nav>
			<div class="border-t border-slate-800 pt-8">
				<div class="flex flex-wrap justify-center gap-6 mb-4">
					<a href="https://www.instagram.com/portalomontador/" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-amber-400 transition-colors" aria-label="Instagram">
						<span class="material-symbols-outlined text-2xl">camera_alt</span>
					</a>
					<a href="/privacidade" class="text-slate-500 hover:text-amber-400 text-sm transition-colors">Política de Privacidade</a>
					<a href="/termos" class="text-slate-500 hover:text-amber-400 text-sm transition-colors">Termos de Uso</a>
					<a href="/contato" class="text-slate-500 hover:text-amber-400 text-sm transition-colors">Contato</a>
				</div>
				<p class="text-slate-500 text-sm">© 2026 Portal O Montador de Móveis. Todos os direitos reservados.</p>
			</div>
		</div>
	</footer>

	<BottomNavBar />
</Layout>

<script define:vars={{ locaisDeAtendimentoData }}>window.locaisDeAtendimentoData = locaisDeAtendimentoData;</script>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		const estadoSelect = document.getElementById('estado');
		const cidadeSelect = document.getElementById('cidade');

		const estadosBrasileiros = {
			'AL': 'Alagoas', 'AM': 'Amazonas', 'BA': 'Bahia', 'CE': 'Ceará',
			'DF': 'Distrito Federal', 'GO': 'Goiás', 'MA': 'Maranhão', 'MG': 'Minas Gerais',
			'MS': 'Mato Grosso do Sul', 'MT': 'Mato Grosso', 'PA': 'Pará', 'PB': 'Paraíba',
			'PE': 'Pernambuco', 'PI': 'Piauí', 'PR': 'Paraná', 'RJ': 'Rio de Janeiro',
			'RN': 'Rio Grande do Norte', 'RS': 'Rio Grande do Sul', 'SC': 'Santa Catarina', 'SE': 'Sergipe', 'SP': 'São Paulo',
			'ES': 'Espírito Santo'
		};

		const locaisDeAtendimento = 'locaisDeAtendimentoData' in window ? window.locaisDeAtendimentoData : {};
		console.log('locaisDeAtendimento:', locaisDeAtendimento);
		console.log('keys:', Object.keys(locaisDeAtendimento));

		function carregarEstados() {
			const estadosOrdenados = Object.keys(locaisDeAtendimento).sort();
			estadosOrdenados.forEach(function(uf) {
				const nome = estadosBrasileiros[uf] || uf;
				const option = document.createElement('option');
				option.value = uf;
				option.textContent = nome;
				estadoSelect.appendChild(option);
			});
		}

		estadoSelect.addEventListener('change', function() {
			const ufSelecionado = estadoSelect.value;
			cidadeSelect.innerHTML = '<option disabled selected value="">Selecione a Cidade</option>';
			
			if (locaisDeAtendimento[ufSelecionado]) {
				locaisDeAtendimento[ufSelecionado].sort().forEach(function(cidade) {
					const slug = cidade.toLowerCase()
						.normalize('NFD').replace(/[\u0300-\u036f]/g, '')
						.replace(/[^a-z0-9]/g, '-')
						.replace(/-+/g, '-')
						.replace(/^-|-$/g, '');
					const option = document.createElement('option');
					option.value = slug;
					option.textContent = cidade;
					cidadeSelect.appendChild(option);
				});
				cidadeSelect.disabled = false;
			} else {
				cidadeSelect.disabled = true;
			}
		});

		carregarEstados();

		const form = document.querySelector('form');
		form.addEventListener('submit', function(e) {
			e.preventDefault();
			const estado = estadoSelect.value;
			const cidade = cidadeSelect.value;
			if (!estado || !cidade) {
				alert('Por favor, selecione o Estado e a Cidade.');
				return;
			}
			window.location.href = '/' + cidade;
		});
	});
</script>