---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import BottomNavBar from '../components/BottomNavBar.astro';
import MontadorCard from '../components/MontadorCard.astro';
import { supabase } from '../lib/supabase';

const locaisDeAtendimento = {
	"AL": ["Maceió"],
	"AM": ["Manaus"],
	"BA": ["Salvador"],
	"CE": ["Fortaleza"],
	"DF": ["Brasília"],
	"GO": ["Goiânia"],
	"MA": ["São Luís"],
	"MG": ["Belo Horizonte", "Uberlândia"],
	"MS": ["Campo Grande"],
	"MT": ["Cuiabá"],
	"PA": ["Belém"],
	"PB": ["João Pessoa"],
	"PE": ["Jaboatão dos Guararapes", "Recife"],
	"PI": ["Teresina"],
	"PR": ["Curitiba"],
	"RJ": ["Duque de Caxias", "Rio de Janeiro", "São Gonçalo"],
	"RN": ["Natal"],
	"RS": ["Alvorada", "Bento Gonçalves", "Cachoeirinha", "Campo Bom", "Canoas", "Dois Irmãos", "Estância Velha", "Esteio", "Gravataí", "Igrejinha", "Ivoti", "Morro Reuter", "Nova Santa Rita", "Novo Hamburgo", "Parobé", "Pelotas", "Portão", "Porto Alegre", "Sapiranga", "Sapucaia do Sul", "São Leopoldo", "Taquara", "Viamão"],
	"SE": ["Aracaju"],
	"SP": ["Campinas", "Guarulhos", "Osasco", "Ribeirão Preto", "Santo André", "São Bernardo do Campo", "São José dos Campos", "São Paulo", "Sorocaba"]
};

export function getStaticPaths() {
	function formatarUrl(cidade: string): string {
		return cidade.toLowerCase().replace(/\s+/g, '-').normalize('NFD').replace(/[\u0300-\u036f]/g, '');
	}

	const locais = {
		"AL": ["Maceió"],
		"AM": ["Manaus"],
		"BA": ["Salvador"],
		"CE": ["Fortaleza"],
		"DF": ["Brasília"],
		"GO": ["Goiânia"],
		"MA": ["São Luís"],
		"MG": ["Belo Horizonte", "Uberlândia"],
		"MS": ["Campo Grande"],
		"MT": ["Cuiabá"],
		"PA": ["Belém"],
		"PB": ["João Pessoa"],
		"PE": ["Jaboatão dos Guararapes", "Recife"],
		"PI": ["Teresina"],
		"PR": ["Curitiba"],
		"RJ": ["Duque de Caxias", "Rio de Janeiro", "São Gonçalo"],
		"RN": ["Natal"],
		"RS": ["Alvorada", "Bento Gonçalves", "Cachoeirinha", "Campo Bom", "Canoas", "Dois Irmãos", "Estância Velha", "Esteio", "Gravataí", "Igrejinha", "Ivoti", "Morro Reuter", "Nova Santa Rita", "Novo Hamburgo", "Parobé", "Pelotas", "Portão", "Porto Alegre", "Sapiranga", "Sapucaia do Sul", "São Leopoldo", "Taquara", "Viamão"],
		"SE": ["Aracaju"],
		"SP": ["Campinas", "Guarulhos", "Osasco", "Ribeirão Preto", "Santo André", "São Bernardo do Campo", "São José dos Campos", "São Paulo", "Sorocaba"]
	};

	const paths: { params: { cidade: string }; props: { nomeCidade: string } }[] = [];
	
	for (const [, cidades] of Object.entries(locais)) {
		for (const cidade of cidades) {
			paths.push({
				params: { cidade: formatarUrl(cidade) },
				props: { nomeCidade: cidade }
			});
		}
	}
	
	return paths;
}

const { nomeCidade } = Astro.props;

const { data: montadoresBanco } = await supabase
	.from('montadores_pendentes')
	.select('*');

const montadoresFiltrados = (montadoresBanco || []).filter((m: any) => {
	const cidadeMatch = m.cidade_estado?.toLowerCase().includes(nomeCidade.toLowerCase());
	return cidadeMatch;
});
---

<Layout title={`Montadores em ${nomeCidade} - O Montador de Móveis`}>
	<Header />

	<main class="max-w-7xl mx-auto px-4">
		<section class="pt-16 pb-12 relative overflow-hidden">
			<div class="absolute top-0 right-0 w-64 h-64 bg-[#ffb800]/20 rounded-full blur-[80px] -z-10 translate-x-1/2 -translate-y-1/4"></div>
			<div>
				<a href="/" class="inline-flex items-center gap-1 text-[#514532] mb-6 text-sm">
					<span class="material-symbols-outlined text-sm">arrow_back</span>
					Voltar
				</a>
				<h1 class="font-headline text-[2rem] leading-[1.1] font-bold text-[#0a1a3c] mb-2 tracking-[-0.02em]">
					Montadores em {nomeCidade}
				</h1>
				<p class="text-[#514532] mb-8">{montadoresFiltrados.length} profissional(is) encontrado(s)</p>

				{montadoresFiltrados.length === 0 ? (
					<div class="text-center py-12">
						<span class="material-symbols-outlined text-6xl text-[#514532]/30">search_off</span>
						<p class="text-[#514532] mt-4">Nenhum montador encontrado nesta cidade ainda.</p>
						<a href="/cadastro" class="inline-block mt-4 text-[#ffb800] font-bold">Seja o primeiro a se cadastrar!</a>
					</div>
				) : (
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
						{montadoresFiltrados.map((montador: any) => (
							<MontadorCard 
								nome={montador.nome_completo}
								imagem={montador.foto_url}
								avaliacao={montador.nota || 0}
								totalAvaliacoes={montador.avaliacoes || 0}
								cidade={nomeCidade}
								estado={montador.cidade_estado?.split(' - ')[1] || ''}
								especialidades={[]}
								online={true}
							/>
						))}
					</div>
				)}
			</div>
		</section>
	</main>

	<BottomNavBar />
</Layout>