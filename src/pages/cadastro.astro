---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Cadastrar - O Montador de Móveis" description="Cadastre-se como montador de móveis no Portal O Montador e conquiste novos clientes na sua região." url="https://portal.omontadordemoveis.com/cadastro">
	<Header />

	<main class="max-w-7xl mx-auto px-4">
		<section class="pt-20 pb-12 relative overflow-hidden">
			<a href="/" class="hidden md:inline-flex items-center gap-1 text-[#514532] mb-6 text-sm">
				<span class="material-symbols-outlined text-sm">arrow_back</span>
				Voltar
			</a>
			<div class="absolute top-0 right-0 w-64 h-64 bg-[#ffb800]/20 rounded-full blur-[80px] -z-10 translate-x-1/2 -translate-y-1/4"></div>
			<div class="max-w-xl mx-auto">
				<div class="text-center mb-10">
					<span class="inline-flex items-center justify-center w-16 h-16 bg-[#ffb800] rounded-full mb-6">
						<span class="material-symbols-outlined text-3xl text-[#6b4c00]">handshake</span>
					</span>
					<h1 class="font-headline text-3xl font-bold text-[#0a1a3c] mb-3">
						Faça Parte da Nossa Rede
					</h1>
					<p class="text-[#514532] text-lg">
						Cadastre-se agora e conquiste novos clientes na sua região
					</p>
				</div>

				<form id="cadastro-form" class="space-y-6 bg-white rounded-xl p-8 ambient-shadow">
					<div>
						<label for="nome" class="block text-sm font-medium text-[#0a1a3c] mb-2">
							Nome Completo
						</label>
						<div class="relative">
							<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#514532]/60">person</span>
							<input
								type="text"
								id="nome"
								name="nome"
								placeholder="Seu nome completo"
								required
								class="w-full h-14 pl-12 pr-4 bg-[#f2f3ff] text-[#0a1a3c] font-body text-base border-none rounded-md appearance-none focus:ring-2 focus:ring-[#ffb800] focus:ring-offset-2 focus:ring-offset-white transition-all placeholder:text-[#514532]/50"
							/>
						</div>
					</div>

					<div>
						<label for="whatsapp" class="block text-sm font-medium text-[#0a1a3c] mb-2">
							WhatsApp
						</label>
						<div class="relative">
							<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#514532]/60">chat</span>
							<input
								type="tel"
								id="whatsapp"
								name="whatsapp"
								placeholder="(11) 99999-9999"
								required
								class="w-full h-14 pl-12 pr-4 bg-[#f2f3ff] text-[#0a1a3c] font-body text-base border-none rounded-md appearance-none focus:ring-2 focus:ring-[#ffb800] focus:ring-offset-2 focus:ring-offset-white transition-all placeholder:text-[#514532]/50"
							/>
						</div>
					</div>

					<div>
						<label for="estado" class="block text-sm font-medium text-[#0a1a3c] mb-2">
							Estado
						</label>
						<div class="relative">
							<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#514532]/60">map</span>
							<select
								id="estado"
								name="estado"
								required
								class="w-full h-14 pl-12 pr-4 bg-[#f2f3ff] text-[#0a1a3c] font-body text-base border-none rounded-md appearance-none focus:ring-2 focus:ring-[#ffb800] focus:ring-offset-2 focus:ring-offset-white transition-all"
							>
								<option disabled selected value="">Selecione o Estado</option>
							</select>
							<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-[#514532] pointer-events-none">expand_more</span>
						</div>
					</div>

					<div>
						<label for="cidade" class="block text-sm font-medium text-[#0a1a3c] mb-2">
							Cidade
						</label>
						<div class="relative">
							<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#514532]/60">location_city</span>
							<select
								id="cidade"
								name="cidade"
								required
								disabled
								class="w-full h-14 pl-12 pr-4 bg-[#f2f3ff] text-[#0a1a3c] font-body text-base border-none rounded-md appearance-none focus:ring-2 focus:ring-[#ffb800] focus:ring-offset-2 focus:ring-offset-white transition-all disabled:opacity-50 disabled:cursor-not-allowed"
							>
								<option disabled selected value="">Selecione uma cidade</option>
							</select>
							<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-[#514532] pointer-events-none">expand_more</span>
						</div>
					</div>

					<div>
						<label for="google-empresas" class="block text-sm font-medium text-[#0a1a3c] mb-2">
							Link do perfil no Google (Opcional)
						</label>
						<div class="relative">
							<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#514532]/60">link</span>
							<input
								type="url"
								id="google-empresas"
								name="googleEmpresas"
								placeholder="https://business.google.com/..."
								class="w-full h-14 pl-12 pr-4 bg-[#f2f3ff] text-[#0a1a3c] font-body text-base border-none rounded-md appearance-none focus:ring-2 focus:ring-[#ffb800] focus:ring-offset-2 focus:ring-offset-white transition-all placeholder:text-[#514532]/50"
							/>
						</div>
						<p class="mt-2 text-sm text-[#514532]/70">
							Recomendado para puxar suas estrelas e quantidade de avaliações. Deixe em branco se não tiver.
						</p>
					</div>

					<div class="pt-4">
						<button type="submit" id="submit-btn" class="w-full h-14 bg-gradient-to-b from-[#ffb800] to-[#f0ad00] text-[#6b4c00] font-headline font-bold text-lg rounded-md flex items-center justify-center gap-2 hover:-translate-y-0.5 transition-transform active:scale-[0.98] shadow-sm disabled:opacity-70 disabled:cursor-not-allowed">
							<span class="material-symbols-outlined" style="font-variation-settings: 'wght' 600;" id="btn-icon">send</span>
							<span id="btn-text">Cadastrar</span>
						</button>
					</div>
				</form>

				<div id="success-message" class="hidden mt-6 bg-[#0a1a3c] border border-slate-700 rounded-xl p-6 text-center">
					<span class="inline-flex items-center justify-center w-16 h-16 bg-[#1e3a5f] rounded-full mb-4">
						<span class="material-symbols-outlined text-3xl text-[#ffb800]">check_circle</span>
					</span>
					<h2 class="font-headline text-xl font-bold text-white mb-2">Cadastro enviado com sucesso!</h2>
					<p class="text-slate-300">Cadastro recebido com sucesso! Seu perfil passará por nossa curadoria de qualidade e, sendo aprovado, será publicado no portal em breve.</p>
					<a href="/" class="inline-block mt-4 text-[#ffb800] hover:text-[#f0ad00] font-medium">
						Voltar para_home
					</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<script>
	import { createClient } from '@supabase/supabase-js';

	const supabaseUrl = 'https://zbxclibijjngvorcynpw.supabase.co';
	const supabaseAnonKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InpieGNsaWJpampuZ3ZvcmN5bnB3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY2NDE2OTIsImV4cCI6MjA5MjIxNzY5Mn0.yL21n_56GRd8xb1NPfKNYSyvGRTMHu5SC96u7BuzmfA';
	const supabase = createClient(supabaseUrl, supabaseAnonKey);

	const form = document.getElementById('cadastro-form');
	const submitBtn = document.getElementById('submit-btn');
	const btnText = document.getElementById('btn-text');
	const btnIcon = document.getElementById('btn-icon');
	const successMessage = document.getElementById('success-message');
	const estadoSelect = document.getElementById('estado') as HTMLSelectElement;
	const cidadeSelect = document.getElementById('cidade') as HTMLSelectElement;

	async function carregarEstados() {
		try {
			const response = await fetch('https://servicodados.ibge.gov.br/api/v1/localidades/estados?orderBy=nome');
			const estados = await response.json();
			
			estados.forEach((estado: { nome: string; sigla: string }) => {
				const option = document.createElement('option');
				option.value = estado.sigla;
				option.textContent = estado.nome;
				estadoSelect.appendChild(option);
			});
		} catch (error) {
			console.error('Erro ao carregar estados:', error);
		}
	}

	async function carregarCidades(uf: string) {
		try {
			cidadeSelect.innerHTML = '<option disabled selected value="">Carregando...</option>';
			cidadeSelect.disabled = true;

			const response = await fetch(`https://servicodados.ibge.gov.br/api/v1/localidades/estados/${uf}/municipios`);
			const municipios = await response.json();

			cidadeSelect.innerHTML = '<option disabled selected value="">Selecione uma cidade</option>';
			
			municipios.forEach((municipio: { nome: string }) => {
				const option = document.createElement('option');
				option.value = municipio.nome;
				option.textContent = municipio.nome;
				cidadeSelect.appendChild(option);
			});

			cidadeSelect.disabled = false;
		} catch (error) {
			console.error('Erro ao carregar cidades:', error);
			cidadeSelect.innerHTML = '<option disabled selected value="">Erro ao carregar</option>';
		}
	}

	estadoSelect?.addEventListener('change', () => {
		const uf = estadoSelect.value;
		if (uf) {
			carregarCidades(uf);
		}
	});

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();

		btnText.textContent = 'Enviando...';
		btnIcon.textContent = 'hourglass_empty';
		submitBtn.disabled = true;

		const formData = new FormData(form);
		const estado = formData.get('estado') as string;
		const cidade = formData.get('cidade') as string;
		const cidadeEstado = `${cidade} - ${estado}`;

		const linkGoogle = formData.get('googleEmpresas');
		const linkGoogleEmpresas = linkGoogle && linkGoogle.toString().trim() ? linkGoogle.toString().trim() : null;

		const dados = {
			nome_completo: formData.get('nome'),
			whatsapp: formData.get('whatsapp'),
			cidade_estado: cidadeEstado,
			link_google_empresas: linkGoogleEmpresas
		};

		const { error } = await supabase
			.from('montadores_pendentes')
			.insert([dados]);

		if (error) {
			console.error('Erro ao cadastrar:', error);
			btnText.textContent = 'Tentar Novamente';
			btnIcon.textContent = 'error';
			submitBtn.disabled = false;
			alert('Erro ao cadastrar. Tente novamente.');
		} else {
			form.classList.add('hidden');
			successMessage.classList.remove('hidden');
		}
	});

	carregarEstados();
</script>