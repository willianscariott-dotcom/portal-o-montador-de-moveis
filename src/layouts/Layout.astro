---
interface Props {
	title: string;
	description?: string;
	url?: string;
	image?: string;
}

const { title, description = "Encontre montadores de móveis profissionais próximos de você. Serviço rápido, seguro e com garantia. Solicite seu orçamento agora!", url = "https://portal.omontadordemoveis.com", image = "https://portal.omontadordemoveis.com/favicon.svg" } = Astro.props;

const siteUrl = "https://portal.omontadordemoveis.com";
const ogImage = image || `${siteUrl}/favicon.svg`;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' https://www.googletagmanager.com; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://servicodados.ibge.gov.br https://*.supabase.co;" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
		<meta name="generator" content={Astro.generator} />
		<meta name="google-site-verification" content="e5f742fa0babeddf" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={url} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@400;700;800&display=swap" rel="stylesheet" />
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={url} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content="/og-image.png" />
		<meta property="og:site_name" content="Portal O Montador de Móveis" />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-Y8D7HP1H4Q"></script>
		<script>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-Y8D7HP1H4Q');
		</script>
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@graph": [
				{
					"@type": "Organization",
					"name": "Portal O Montador de Móveis",
					"url": "https://portal.omontadordemoveis.com",
					"logo": "https://portal.omontadordemoveis.com/favicon.svg",
					"sameAs": [
						"https://instagram.com/omontador",
						"https://facebook.com/omontador"
					]
				},
				{
					"@type": "WebSite",
					"name": "Portal O Montador de Móveis",
					"url": "https://portal.omontadordemoveis.com",
					"potentialAction": {
						"@type": "SearchAction",
						"target": {
							"@type": "EntryPoint",
							"urlTemplate": "https://portal.omontadordemoveis.com/?s={search_term_string}"
						},
						"query-input": "required name=search_term_string"
					}
				}
			]
		}
		</script>
	</head>
	<body class="font-body text-[#0a1a3c] antialiased pt-16 pb-24 selection:bg-[#ffb800] selection:text-[#6b4c00]">
		<slot />
	</body>
</html>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@400;700;800&display=swap');
	@import url('https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap');

	:root {
		--color-surface-container-lowest: #ffffff;
		--color-surface-container-low: #f2f3ff;
		--color-surface-container: #eaedff;
		--color-surface-container-high: #e2e7ff;
		--color-surface-container-highest: #dae2ff;
		--color-surface: #faf8ff;
		--color-on-surface: #0a1a3c;
		--color-on-surface-variant: #514532;
		--color-primary: #7c5800;
		--color-primary-container: #ffb800;
		--color-on-primary-container: #6b4c00;
		--color-secondary: #775a20;
		--color-secondary-container: #fdd48e;
		--color-on-secondary-container: #785a20;
		--color-tertiary: #00687b;
		--color-tertiary-container: #00d7fe;
		--color-on-tertiary-container: #005a6b;
	}

	.font-headline {
		font-family: 'Manrope', sans-serif;
	}

	.font-body {
		font-family: 'Inter', sans-serif;
	}

	.material-symbols-outlined {
		font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
	}

	.ambient-shadow {
		box-shadow: 0 40px 60px -10px rgba(10, 26, 60, 0.06);
	}

	.ambient-shadow-sm {
		box-shadow: 0 20px 40px -10px rgba(10, 26, 60, 0.04);
	}

	.pb-safe {
		padding-bottom: env(safe-area-inset-bottom);
	}
</style>