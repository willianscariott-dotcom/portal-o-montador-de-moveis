---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import BottomNavBar from '../components/BottomNavBar.astro';

const citiesData = [
	{ id: "maceio", nome: "Maceió", estado: "Alagoas", estadoSigla: "AL" },
	{ id: "manaus", nome: "Manaus", estado: "Amazonas", estadoSigla: "AM" },
	{ id: "salvador", nome: "Salvador", estado: "Bahia", estadoSigla: "BA" },
	{ id: "fortaleza", nome: "Fortaleza", estado: "Ceará", estadoSigla: "CE" },
	{ id: "brasilia", nome: "Brasília", estado: "Distrito Federal", estadoSigla: "DF" },
	{ id: "goiania", nome: "Goiânia", estado: "Goiás", estadoSigla: "GO" },
	{ id: "sao-luis", nome: "São Luís", estado: "Maranhão", estadoSigla: "MA" },
	{ id: "belo-horizonte", nome: "Belo Horizonte", estado: "Minas Gerais", estadoSigla: "MG" },
	{ id: "uberlandia", nome: "Uberlândia", estado: "Minas Gerais", estadoSigla: "MG" },
	{ id: "campo-grande", nome: "Campo Grande", estado: "Mato Grosso do Sul", estadoSigla: "MS" },
	{ id: "cuiaba", nome: "Cuiabá", estado: "Mato Grosso", estadoSigla: "MT" },
	{ id: "belem", nome: "Belém", estado: "Pará", estadoSigla: "PA" },
	{ id: "joao-pessoa", nome: "João Pessoa", estado: "Paraíba", estadoSigla: "PB" },
	{ id: "recife", nome: "Recife", estado: "Pernambuco", estadoSigla: "PE" },
	{ id: "teresina", nome: "Teresina", estado: "Piauí", estadoSigla: "PI" },
	{ id: "curitiba", nome: "Curitiba", estado: "Paraná", estadoSigla: "PR" },
	{ id: "rio-de-janeiro", nome: "Rio de Janeiro", estado: "Rio de Janeiro", estadoSigla: "RJ" },
	{ id: "natal", nome: "Natal", estado: "Rio Grande do Norte", estadoSigla: "RN" },
	{ id: "porto-alegre", nome: "Porto Alegre", estado: "Rio Grande do Sul", estadoSigla: "RS" },
	{ id: "canoas", nome: "Canoas", estado: "Rio Grande do Sul", estadoSigla: "RS" },
	{ id: "pelotas", nome: "Pelotas", estado: "Rio Grande do Sul", estadoSigla: "RS" },
	{ id: "cachoerinha", nome: "Cachoeirinha", estado: "Rio Grande do Sul", estadoSigla: "RS" },
	{ id: "gravatai", nome: "Gravataí", estado: "Rio Grande do Sul", estadoSigla: "RS" },
	{ id: "viamão", nome: "Viamão", estado: "Rio Grande do Sul", estadoSigla: "RS" },
	{ id: "sao-leopoldo", nome: "São Leopoldo", estado: "Rio Grande do Sul", estadoSigla: "RS" },
	{ id: "novo-hamburgo", nome: "Novo Hamburgo", estado: "Rio Grande do Sul", estadoSigla: "RS" },
	{ id: "aracaju", nome: "Aracaju", estado: "Sergipe", estadoSigla: "SE" },
	{ id: "sao-paulo", nome: "São Paulo", estado: "São Paulo", estadoSigla: "SP" },
	{ id: "campinas", nome: "Campinas", estado: "São Paulo", estadoSigla: "SP" },
	{ id: "guarulhos", nome: "Guarulhos", estado: "São Paulo", estadoSigla: "SP" },
	{ id: "sao-bernardo-do-campo", nome: "São Bernardo do Campo", estado: "São Paulo", estadoSigla: "SP" },
	{ id: "osasco", nome: "Osasco", estado: "São Paulo", estadoSigla: "SP" },
	{ id: "ribeirao-preto", nome: "Ribeirão Preto", estado: "São Paulo", estadoSigla: "SP" }
];
---

<Layout title="Portal O Montador - Encontre Montadores de Móveis Próximos a Você">
	<Header />

	<main>
		<section class="px-6 pt-16 pb-12 relative overflow-hidden">
			<div class="absolute top-0 right-0 w-64 h-64 bg-[#ffb800]/20 rounded-full blur-[80px] -z-10 translate-x-1/2 -translate-y-1/4"></div>
			<div class="max-w-6xl mx-auto grid md:grid-cols-2 items-center gap-8">
				<div>
					<h1 class="font-headline text-[2.5rem] leading-[1.1] font-bold text-[#0a1a3c] mb-4 tracking-[-0.02em]">
						Encontre os Melhores Montadores de Móveis do Brasil
					</h1>
					<p class="text-lg text-[#514532] mb-8">
						O maior e mais seguro portal de montagem. Presente em mais de 15 estados e 40 cidades. Conectamos você a profissionais rigorosamente avaliados.
					</p>
					<div class="bg-white rounded-xl p-6 ambient-shadow relative z-10">
						<form class="space-y-4">
							<div class="relative">
								<label class="sr-only" for="estado">Estado</label>
								<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#514532]/60">map</span>
								<select class="w-full h-14 pl-12 pr-4 bg-[#f2f3ff] text-[#0a1a3c] font-body text-base border-none rounded-md appearance-none focus:ring-0 focus:border-b-2 focus:border-[#7c5800] transition-all" id="estado" name="estado" required>
									<option disabled selected value="">Carregando Estados...</option>
								</select>
								<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-[#514532] pointer-events-none">expand_more</span>
							</div>
							<div class="relative">
								<label class="sr-only" for="cidade">Cidade</label>
								<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#514532]/60">location_city</span>
								<select class="w-full h-14 pl-12 pr-4 bg-[#f2f3ff] text-[#0a1a3c] font-body text-base border-none rounded-md appearance-none focus:ring-0 focus:border-b-2 focus:border-[#7c5800] transition-all" id="cidade" name="cidade" required disabled>
									<option disabled selected value="">Selecione um Estado primeiro</option>
								</select>
								<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-[#514532] pointer-events-none">expand_more</span>
							</div>
							<button type="submit" class="w-full h-14 mt-2 bg-gradient-to-b from-[#ffb800] to-[#f0ad00] text-[#6b4c00] font-headline font-bold text-lg rounded-md flex items-center justify-center gap-2 hover:-translate-y-0.5 transition-transform active:scale-[0.98] shadow-sm">
								<span class="material-symbols-outlined" style="font-variation-settings: 'wght' 600;">search</span>
								Buscar
							</button>
						</form>
					</div>
				</div>
				<div class="hidden md:block">
					<img src="/hero-image.webp" alt="Montador de Móveis profissional" class="w-full max-w-lg mx-auto drop-shadow-2xl object-contain" />
				</div>
			</div>
		</section>

		<section class="px-6 py-12 bg-[#0a1a3c]">
			<div class="max-w-6xl mx-auto">
				<h2 class="font-headline text-xl font-bold text-white mb-6">Principais Cidades Atendidas</h2>
				<div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
					{citiesData.map((cidade) => (
						<a href={`/${cidade.id}`} class="text-[#ffb800] hover:text-white font-medium text-sm py-2 px-3 rounded-md transition-colors hover:bg-white/10">
							{cidade.nome}
						</a>
					))}
				</div>
			</div>
		</section>
	</main>

	<BottomNavBar />
</Layout>

<script>
	const estadoSelect = document.getElementById('estado');
	const cidadeSelect = document.getElementById('cidade');

	const estadosBrasileiros = {
		'AL': 'Alagoas', 'AM': 'Amazonas', 'BA': 'Bahia', 'CE': 'Ceará',
		'DF': 'Distrito Federal', 'GO': 'Goiás', 'MA': 'Maranhão', 'MG': 'Minas Gerais',
		'MS': 'Mato Grosso do Sul', 'MT': 'Mato Grosso', 'PA': 'Pará', 'PB': 'Paraíba',
		'PE': 'Pernambuco', 'PI': 'Piauí', 'PR': 'Paraná', 'RJ': 'Rio de Janeiro',
		'RN': 'Rio Grande do Norte', 'RS': 'Rio Grande do Sul', 'SE': 'Sergipe', 'SP': 'São Paulo'
	};

	const locaisDeAtendimento = {
		"AL": ["Maceió"], "AM": ["Manaus"], "BA": ["Salvador"], "CE": ["Fortaleza"],
		"DF": ["Brasília"], "GO": ["Goiânia"], "MA": ["São Luís"], "MG": ["Belo Horizonte", "Uberlândia"],
		"MS": ["Campo Grande"], "MT": ["Cuiabá"], "PA": ["Belém"], "PB": ["João Pessoa"],
		"PE": ["Jaboatão dos Guararapes", "Recife"], "PI": ["Teresina"], "PR": ["Curitiba"],
		"RJ": ["Duque de Caxias", "Rio de Janeiro", "São Gonçalo"], "RN": ["Natal"],
		"RS": ["Alvorada", "Bento Gonçalves", "Cachoeirinha", "Campo Bom", "Canoas", "Dois Irmãos", "Estância Velha", "Esteio", "Gravataí", "Igrejinha", "Ivoti", "Morro Reuter", "Nova Santa Rita", "Novo Hamburgo", "Parobé", "Pelotas", "Portão", "Porto Alegre", "Sapiranga", "Sapucaia do Sul", "São Leopoldo", "Taquara", "Viamão"],
		"SE": ["Aracaju"], "SP": ["Campinas", "Guarulhos", "Osasco", "Ribeirão Preto", "Santo André", "São Bernardo do Campo", "São José dos Campos", "São Paulo", "Sorocaba"]
	};

	function carregarEstados() {
		const estadosOrdenados = Object.keys(locaisDeAtendimento).sort();
		estadoSelect.innerHTML = '<option disabled selected value="">Selecione o Estado</option>';
		estadosOrdenados.forEach(function(uf) {
			const nome = estadosBrasileiros[uf] || uf;
			const option = document.createElement('option');
			option.value = uf;
			option.textContent = nome;
			estadoSelect.appendChild(option);
		});
	}

	estadoSelect.addEventListener('change', function() {
		const ufSelecionado = estadoSelect.value;
		cidadeSelect.innerHTML = '<option disabled selected value="">Selecione a Cidade</option>';
		
		if (locaisDeAtendimento[ufSelecionado]) {
			locaisDeAtendimento[ufSelecionado].sort().forEach(function(cidade) {
				const option = document.createElement('option');
				option.value = cidade.toLowerCase().replace(/\s+/g, '-').normalize('NFD').replace(/[\u0300-\u036f]/g, '');
				option.textContent = cidade;
				cidadeSelect.appendChild(option);
			});
			cidadeSelect.disabled = false;
		} else {
			cidadeSelect.disabled = true;
		}
	});

	carregarEstados();

	const form = document.querySelector('form');
	form.addEventListener('submit', function(e) {
		e.preventDefault();
		const estado = estadoSelect.value;
		const cidade = cidadeSelect.value;
		if (!estado || !cidade) {
			alert('Por favor, selecione o Estado e a Cidade.');
			return;
		}
		window.location.href = '/' + cidade;
	});
</script>