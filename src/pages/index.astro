---

<Layout title="O Montador de Móveis">
	<Header />

	<main>
		<section class="px-6 pt-16 pb-12 relative overflow-hidden">
			<div class="absolute top-0 right-0 w-64 h-64 bg-[#ffb800]/20 rounded-full blur-[80px] -z-10 translate-x-1/2 -translate-y-1/4"></div>
			<div class="max-w-6xl mx-auto grid md:grid-cols-2 items-center gap-8">
				<div>
					<h1 class="font-headline text-[2.5rem] leading-[1.1] font-bold text-[#0a1a3c] mb-8 tracking-[-0.02em]">
						Encontre os melhores montadores na sua cidade
					</h1>
					<div class="bg-white rounded-xl p-6 ambient-shadow relative z-10">
						<form action="/[cidade]" method="GET" class="space-y-4">
							<div class="relative">
								<label class="sr-only" for="estado">Estado</label>
								<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#514532]/60">map</span>
								<select class="w-full h-14 pl-12 pr-4 bg-[#f2f3ff] text-[#0a1a3c] font-body text-base border-none rounded-md appearance-none focus:ring-0 focus:border-b-2 focus:border-[#7c5800] transition-all" id="estado" name="estado" required>
									<option disabled selected value="">Carregando Estados...</option>
								</select>
								<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-[#514532] pointer-events-none">expand_more</span>
							</div>
							<div class="relative">
								<label class="sr-only" for="cidade">Cidade</label>
								<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#514532]/60">location_city</span>
								<select class="w-full h-14 pl-12 pr-4 bg-[#f2f3ff] text-[#0a1a3c] font-body text-base border-none rounded-md appearance-none focus:ring-0 focus:border-b-2 focus:border-[#7c5800] transition-all" id="cidade" name="cidade" required disabled>
									<option disabled selected value="">Selecione um Estado primeiro</option>
								</select>
								<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-[#514532] pointer-events-none">expand_more</span>
							</div>
							<button type="submit" class="w-full h-14 mt-2 bg-gradient-to-b from-[#ffb800] to-[#f0ad00] text-[#6b4c00] font-headline font-bold text-lg rounded-md flex items-center justify-center gap-2 hover:-translate-y-0.5 transition-transform active:scale-[0.98] shadow-sm">
								<span class="material-symbols-outlined" style="font-variation-settings: 'wght' 600;">search</span>
								Buscar
							</button>
						</form>
					</div>
				</div>
				<div class="hidden md:block">
					<img src="/hero-image.webp" alt="Montador de Móveis com Serviço Excelente" class="w-full max-w-lg mx-auto drop-shadow-2xl object-contain" />
				</div>
			</div>
		</section>

		<section class="px-6 py-12 bg-[#f2f3ff]/50 relative">
			<div class="max-w-md mx-auto">
				<div class="flex items-center justify-between mb-8">
					<h2 class="font-headline text-2xl font-bold text-[#0a1a3c] tracking-tight">Profissionais em Destaque</h2>
					<span class="material-symbols-outlined text-[#ffb800]" style="font-variation-settings: 'FILL' 1;">stars</span>
				</div>
				<div class="grid grid-cols-1 gap-5">
					{montadores.map((montador) => (
						<MontadorCard {...montador} />
					))}
				</div>
			</div>
		</section>
	</main>

	<BottomNavBar />
</Layout>

<script>
	import { supabase } from '../lib/supabase';

	const estadoSelect = document.getElementById('estado') as HTMLSelectElement;
	const cidadeSelect = document.getElementById('cidade') as HTMLSelectElement;

	const estadosBrasileiros: Record<string, string> = {
		'AC': 'Acre', 'AL': 'Alagoas', 'AP': 'Amapá', 'AM': 'Amazonas',
		'BA': 'Bahia', 'CE': 'Ceará', 'DF': 'Distrito Federal', 'ES': 'Espírito Santo',
		'GO': 'Goiás', 'MA': 'Maranhão', 'MT': 'Mato Grosso', 'MS': 'Mato Grosso do Sul',
		'MG': 'Minas Gerais', 'PA': 'Pará', 'PB': 'Paraíba', 'PR': 'Paraná',
		'PE': 'Pernambuco', 'PI': 'Piauí', 'RJ': 'Rio de Janeiro', 'RN': 'Rio Grande do Norte',
		'RS': 'Rio Grande do Sul', 'RO': 'Rondônia', 'RR': 'Roraima', 'SC': 'Santa Catarina',
		'SP': 'São Paulo', 'SE': 'Sergipe', 'TO': 'Tocantins'
	};

	let cidadesPorEstado: Record<string, string[]> = {};

	async function carregarDados() {
		const { data, error } = await supabase
			.from('montadores_pendentes')
			.select('cidade_estado');

		if (error) {
			console.error('Erro ao carregar dados:', error);
			estadoSelect.innerHTML = '<option disabled selected value="">Erro ao carregar</option>';
			return;
		}

		const cidadesSet = new Set<string>();
		const estadoSet = new Set<string>();

		data.forEach((item: { cidade_estado: string }) => {
			if (item.cidade_estado) {
				cidadesSet.add(item.cidade_estado);
				const partes = item.cidade_estado.split(' - ');
				if (partes.length >= 2) {
					estadoSet.add(partes[partes.length - 1].trim());
				}
			}
		});

		cidadesSet.forEach((cidadeEstado) => {
			const partes = cidadeEstado.split(' - ');
			if (partes.length >= 2) {
				const uf = partes[partes.length - 1].trim();
				const cidade = partes.slice(0, -1).join(' - ').trim();
				if (!cidadesPorEstado[uf]) {
					cidadesPorEstado[uf] = [];
				}
				if (!cidadesPorEstado[uf].includes(cidade)) {
					cidadesPorEstado[uf].push(cidade);
				}
			}
		});

		const estadosOrdenados = Array.from(estadoSet).sort();
		estadoSelect.innerHTML = '<option disabled selected value="">Selecione o Estado</option>';
		estadosOrdenados.forEach((uf) => {
			const nome = estadosBrasileiros[uf] || uf;
			const option = document.createElement('option');
			option.value = uf;
			option.textContent = nome;
			estadoSelect.appendChild(option);
		});
	}

	estadoSelect.addEventListener('change', () => {
		const ufSelecionado = estadoSelect.value;
		cidadeSelect.innerHTML = '<option disabled selected value="">Selecione a Cidade</option>';
		
		if (cidadesPorEstado[ufSelecionado]) {
			cidadesPorEstado[ufSelecionado].sort().forEach((cidade) => {
				const option = document.createElement('option');
				option.value = cidade.toLowerCase().replace(/\s+/g, '-').normalize('NFD').replace(/[\u0300-\u036f]/g, '');
				option.textContent = cidade;
				cidadeSelect.appendChild(option);
			});
			cidadeSelect.disabled = false;
		} else {
			cidadeSelect.disabled = true;
		}
	});

	carregarDados();
</script>